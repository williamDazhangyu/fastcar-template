{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run TS",
            "type": "node",
            "request": "launch",
            "args": [
                "${relativeFile}",
                "serverType=web",
                "serviceId=web-server-1"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run JS",
            "type": "node",
            "request": "launch",
            "program": "${file}"
        },
        {
            "name": "Run APP_NODE",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run APP_PM2",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-pm2.ts"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run mocha",
            "type": "node",
            "request": "launch",
            "program": "${workspaceRoot}/node_modules/mocha/bin/_mocha",
            "stopOnEntry": false,
            "args": [
                "${relativeFile}",
                "--no-timeouts"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": null,
            "env": {
                "NODE_ENV": "testing"
            },
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ]
        },
        {
            "type": "node",
            "request": "attach",
            "name": "DEBUG",
            "address": "localhost",
            "port": 2000,
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "${workspaceFolder}"
        },
        {
            "name": "Run CENTER-1",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts",
                "serverType=center",
                "serviceId=center-server-1"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run CENTER-2",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts",
                "serverType=center",
                "serviceId=center-server-2"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run WEB-1",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts",
                "serverType=web",
                "serviceId=web-server-1"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run WEB-2",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts",
                "serverType=web",
                "serviceId=web-server-2"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run CHAT-1",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app-node.ts",
                "serverType=chat",
                "serviceId=chat-server-1"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
    ]
}
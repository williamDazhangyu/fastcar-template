{
  "compileOnSave": true,
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "module": "commonjs",
    "target": "ES2023",
    "outDir": "./target",
    "types": [
      "node",
      "mocha"
    ], //在node或mocha环境中运行
    "experimentalDecorators": true, //启用注解
    "emitDecoratorMetadata": true, //启用元数据
    "moduleResolution": "node", //使用node作为模块解析
    "strict": true, //启用严格模式
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "node_modules/**/*"
  ],
  "ts-node": {
    "transpileOnly": true, //开启快速编译
    "require": [ //开启paths支持
      "tsconfig-paths/register"
    ]
  },
  "tsc-alias": {
    "replacers": {
      "base-url": {
        "enabled": false
      }
    }
  },
}
{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run APP",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/src/app.ts",
            ],
            "cwd": "${workspaceRoot}",
            "protocol": "inspector",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run mocha",
            "type": "node",
            "request": "launch",
            "program": "${workspaceRoot}/node_modules/mocha/bin/_mocha",
            "stopOnEntry": false,
            "args": [
                "${relativeFile}",
                "--no-timeouts"
            ],
            "cwd": "${workspaceRoot}",
            "runtimeExecutable": null,
            "env": {
                "NODE_ENV": "testing"
            },
            "protocol": "inspector",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ]
        },
        {
            "name": "Run TS",
            "type": "node",
            "request": "launch",
            "args": [
                "${relativeFile}"
            ],
            "cwd": "${workspaceRoot}",
            "protocol": "inspector",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceRoot}/tsconfig.json"
            }
        },
        {
            "name": "Run JS",
            "type": "node",
            "request": "launch",
            "program": "${file}"
        }
    ]
}